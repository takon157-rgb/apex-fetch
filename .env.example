# Database
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@<pooler_host>:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.<project_ref>:<password>@<pooler_host>:5432/postgres?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_***
CLERK_SECRET_KEY=sk_***
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_WEBHOOK_SECRET=

# Admin
ADMIN_CLERK_ID=user_***
NEXT_PUBLIC_ADMIN_CLERK_ID=user_***

# Google Places (required for local business scraper)
# Enable the Places API + set up billing: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=AIza***

# AI
GEMINI_API_KEY=ai_***
OPENAI_API_KEY=sk_***

# Supabase Storage (optional - for resume file storage)
NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ***

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/***

# Stripe
NEXT_PUBLIC_STRIPE_LINK=https://buy.stripe.com/test_***

# Cron (optional — for automated scraping without a user session)
CRON_SECRET=your_cron_secret_here
